---
import SEOHead from '../components/SEOHead.astro';
---
<!doctype html>
<html lang="en">
<head>
  <SEOHead title="House Cleaning Services - House Cleaning Rockville" description="Rockville house cleaning for recurring maid service, deep cleaning, move-in and move-out cleaning, kitchen cleaning, bathroom cleaning, and apartment cleaning." />
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Bebas+Neue&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <script>
    (function() {
      const theme = localStorage.getItem('theme-preference');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
</head>
<body>

  <div class="emergency-strip">
    <span class="inline-flex items-center gap-2">
      <span class="relative flex h-2 w-2"><span class="ping-dot"></span></span>
      Rockville House Cleaning Appointments - Call Now: <a href="tel:2405550162">(240) 555-0162</a>
    </span>
  </div>

  <header class="site-header is-transparent js-site-header">
    <div class="container">
      <div class="site-header-inner">
        <a href="/" class="logo">
          <div class="logo-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M7 4h10l-1 7a4 4 0 0 1-8 0L7 4Z" fill="white"/><path d="M6 20h12M9 14l-2 6M15 14l2 6" stroke="white" stroke-width="2" stroke-linecap="round"/></svg></div>
          <div class="logo-text"><span class="logo-brand">House Cleaning Rockville</span></div>
        </a>
        <nav class="desktop-nav">
          <a href="/" class="nav-link">Home</a>
          <a href="/services/" class="nav-link is-active">Services</a>
          <a href="/about/" class="nav-link">About</a>
          <a href="/blog/" class="nav-link">Blog</a>
          <a href="/glossary/" class="nav-link">Glossary</a>
          <a href="/contact/" class="nav-link">Contact</a>
        </nav>
        <div class="header-actions">
          <a href="tel:2405550162" class="header-phone">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>(240) 555-0162</span>
          </a>
          <button class="theme-toggle js-theme-toggle" aria-label="Toggle theme">
            <svg class="sun-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            <svg class="moon-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <a href="/contact/" class="header-cta">Book a Cleaning</a>
          <button class="mobile-menu-btn js-mobile-menu-btn" aria-label="Toggle menu">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
        </div>
      </div>
    </div>
    <div class="mobile-menu js-mobile-menu">
      <div class="mobile-menu-inner">
        <a href="/" class="mobile-menu-link">Home</a>
        <a href="/services/" class="mobile-menu-link is-active">Services</a>
        <a href="/about/" class="mobile-menu-link">About</a>
        <a href="/blog/" class="mobile-menu-link">Blog</a>
        <a href="/glossary/" class="mobile-menu-link">Glossary</a>
        <a href="/contact/" class="mobile-menu-link">Contact</a>
        <div class="mobile-menu-footer">
          <a href="tel:2405550162" style="color: white; display: flex; align-items: center; gap: 0.5rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>(240) 555-0162</span>
          </a>
        </div>
        <a href="/contact/" class="mobile-menu-cta">Book a Cleaning</a>
      </div>
    </div>
  </header>

  <main>
    <section class="hero hero-45">
      <div class="hero-bg">
        <img src="/images/hero-home.png" alt="House Cleaning Rockville services" loading="eager">
        <div class="hero-overlay"></div>
      </div>
      <div class="hero-content">
        <div class="container">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <ol class="breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
              <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <a href="/" class="breadcrumb-link" itemprop="item"><span itemprop="name">Home</span></a>
                <meta itemprop="position" content="1">
              </li>
              <li class="breadcrumb-separator">/</li>
              <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <span class="breadcrumb-current" itemprop="name">Services</span>
                <meta itemprop="position" content="2">
              </li>
            </ol>
          </nav>
          <h1 class="hero-headline">House Cleaning Services in Rockville</h1>
          <p class="hero-subheadline">Focused house cleaning support for Rockville homeowners who want responsive help, clear scope, and no vague next steps.</p>
        </div>
      </div>
    </section>

    <section class="section section-lg section-bg-light">
      <div class="container">
        <div class="service-grid service-grid-3 stagger-children">
          <div class="service-card service-card-image-only js-animate animate-on-scroll">
            <div class="service-card-image" style="height: 200px;">
              <img src="/images/service-recurring.png" alt="Recurring Cleaning" loading="lazy">
            </div>
            <div class="service-card-body">
              <h3 class="service-card-title">Recurring Cleaning</h3>
              <p class="service-card-desc">Weekly, biweekly, and monthly cleaning visits tailored to the rooms and routines that matter most.</p>
            </div>
          </div>
          <div class="service-card service-card-image-only js-animate animate-on-scroll">
            <div class="service-card-image" style="height: 200px;">
              <img src="/images/service-deep-cleaning.png" alt="Deep Cleaning" loading="lazy">
            </div>
            <div class="service-card-body">
              <h3 class="service-card-title">Deep Cleaning</h3>
              <p class="service-card-desc">A more detailed reset for buildup, neglected corners, baseboards, fixtures, appliances, and high-touch surfaces.</p>
            </div>
          </div>
          <div class="service-card service-card-image-only js-animate animate-on-scroll">
            <div class="service-card-image" style="height: 200px;">
              <img src="/images/service-move-in.png" alt="Move-In Cleaning" loading="lazy">
            </div>
            <div class="service-card-body">
              <h3 class="service-card-title">Move-In Cleaning</h3>
              <p class="service-card-desc">Fresh-start cleaning before boxes arrive, with attention to cabinets, bathrooms, kitchen surfaces, and floors.</p>
            </div>
          </div>
          <div class="service-card service-card-image-only js-animate animate-on-scroll">
            <div class="service-card-image" style="height: 200px;">
              <img src="/images/service-move-out.png" alt="Move-Out Cleaning" loading="lazy">
            </div>
            <div class="service-card-body">
              <h3 class="service-card-title">Move-Out Cleaning</h3>
              <p class="service-card-desc">Turnover cleaning that helps rentals, condos, and family homes feel ready for walkthroughs or listing photos.</p>
            </div>
          </div>
          <div class="service-card service-card-image-only js-animate animate-on-scroll">
            <div class="service-card-image" style="height: 200px;">
              <img src="/images/service-kitchen.png" alt="Kitchen Cleaning" loading="lazy">
            </div>
            <div class="service-card-body">
              <h3 class="service-card-title">Kitchen Cleaning</h3>
              <p class="service-card-desc">Countertops, sinks, appliance fronts, cabinet touchpoints, stovetop areas, and the everyday mess zones.</p>
            </div>
          </div>
          <div class="service-card service-card-image-only js-animate animate-on-scroll">
            <div class="service-card-image" style="height: 200px;">
              <img src="/images/service-bathroom.png" alt="Bathroom Cleaning" loading="lazy">
            </div>
            <div class="service-card-body">
              <h3 class="service-card-title">Bathroom Cleaning</h3>
              <p class="service-card-desc">Showers, tubs, toilets, vanities, mirrors, tile, fixtures, and the details that make the room feel fresh.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-lg section-bg-light">
      <div class="container">
        <div class="lead-form lead-form-fullwidth js-animate animate-on-scroll">
          <h3 class="lead-form-heading">Request House Cleaning Service</h3>
          <p class="lead-form-subheading">Send the basics and get a clear next step for your Rockville service request.</p>
          <form class="js-lead-form" novalidate>
            <div class="form-grid form-grid-2">
              <div class="form-field">
                <label>Full Name <span class="required">*</span></label>
                <input type="text" placeholder="John Smith" data-required data-label="Full name">
              </div>
              <div class="form-field">
                <label>Phone <span class="required">*</span></label>
                <input type="tel" placeholder="(555) 000-0000" data-required data-label="Phone">
              </div>
              <div class="form-field">
                <label>Email</label>
                <input type="email" placeholder="john@email.com">
              </div>
              <div class="form-field">
                <label>City <span class="required">*</span></label>
                <input type="text" placeholder="Your city" data-required data-label="City">
              </div>
              <div class="form-field" style="grid-column: 1 / -1;">
                <label>How can we help?</label>
                <textarea rows="3" placeholder="Describe your situation..."></textarea>
              </div>
            </div>
            <button type="submit" class="form-submit js-form-submit" style="margin-top: 1rem;">Book a Cleaning</button>
            <p class="form-trust-note">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Clear scope. Local service. No pressure.
            </p>
            <div class="form-success hidden js-form-success">
              <div class="form-success-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </div>
              <h3>Thank You!</h3>
              <p>We've received your request and will contact you within 30 minutes.</p>
            </div>
          </form>
        </div>
      </div>
    </section>

    <section class="section section-lg section-bg-light">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="section-heading js-animate animate-on-scroll">How Service Works</h2>
          <p class="section-subheading js-animate animate-on-scroll">A simple process that keeps your house cleaning request moving from first call to completed visit.</p>
        </div>
        <div class="process-grid process-horizontal">
          <div class="process-step js-animate animate-on-scroll">
            <div class="process-step-number"><span>1</span></div>
            <h3 class="process-step-title">Choose the Visit</h3>
            <p class="process-step-desc">Tell us the home size, rooms, cleaning priorities, and whether this is recurring or a deeper reset.</p>
          </div>
          <div class="process-step js-animate animate-on-scroll">
            <div class="process-step-number"><span>2</span></div>
            <h3 class="process-step-title">Clean Room by Room</h3>
            <p class="process-step-desc">A focused checklist keeps kitchens, baths, bedrooms, and living spaces moving in a logical order.</p>
          </div>
          <div class="process-step js-animate animate-on-scroll">
            <div class="process-step-number"><span>3</span></div>
            <h3 class="process-step-title">Review the Finish</h3>
            <p class="process-step-desc">Final touches, surfaces, and high-use areas are checked before the visit is considered complete.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="trust-bar section-bg-light">
      <div class="container">
        <div class="trust-grid">
          <div class="trust-item js-animate animate-on-scroll">
            <div class="trust-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <div class="trust-value">Insured</div>
              <div class="trust-label">Local Service</div>
            </div>
          </div>
          <div class="trust-item js-animate animate-on-scroll">
            <div class="trust-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <div class="trust-value">Easy</div>
              <div class="trust-label">Scheduling</div>
            </div>
          </div>
          <div class="trust-item js-animate animate-on-scroll">
            <div class="trust-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <div>
              <div class="trust-value">Clear</div>
              <div class="trust-label">Quotes</div>
            </div>
          </div>
          <div class="trust-item js-animate animate-on-scroll">
            <div class="trust-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
            </div>
            <div>
              <div class="trust-value">Trusted</div>
              <div class="trust-label">Rockville Pros</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-lg section-bg-light" id="faq">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="section-heading js-animate animate-on-scroll">House Cleaning FAQs</h2>
          <p class="section-subheading js-animate animate-on-scroll">Common questions Rockville homeowners ask before scheduling house cleaning service.</p>
        </div>
        <div class="faq-list js-faq-list">
          <div class="faq-item js-faq-item">
            <button class="faq-question js-faq-question">
              <span>How fast can I schedule house cleaning in Rockville?</span>
              <svg class="faq-question-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-answer"><div class="faq-answer-inner">Availability depends on visit type and home size, but Rockville appointments are usually offered with flexible weekday and Saturday options.</div></div>
          </div>
          <div class="faq-item js-faq-item">
            <button class="faq-question js-faq-question">
              <span>Do you serve nearby neighborhoods?</span>
              <svg class="faq-question-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-answer"><div class="faq-answer-inner">Yes. Service coverage includes Rockville and nearby Montgomery County communities including North Bethesda, Potomac, Derwood, Aspen Hill, and Gaithersburg.</div></div>
          </div>
          <div class="faq-item js-faq-item">
            <button class="faq-question js-faq-question">
              <span>Can I get pricing before booking?</span>
              <svg class="faq-question-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-answer"><div class="faq-answer-inner">You can get a clear starting scope and next-step guidance before scheduling. Final pricing depends on site conditions, service size, and what the visit requires.</div></div>
          </div>
          <div class="faq-item js-faq-item">
            <button class="faq-question js-faq-question">
              <span>What should I do before the visit?</span>
              <svg class="faq-question-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-answer"><div class="faq-answer-inner">Share priority rooms, access details, pets, parking instructions, and any surfaces or products that need special care.</div></div>
          </div>
          <div class="faq-item js-faq-item">
            <button class="faq-question js-faq-question">
              <span>What areas do you serve?</span>
              <svg class="faq-question-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-answer"><div class="faq-answer-inner">We serve Rockville and nearby Montgomery County communities, with the fastest scheduling usually available closest to Rockville.</div></div>
          </div>
        </div>
      </div>
    </section>
  </main>

