    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="logo">
            <div class="logo-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M7 4h10l-1 7a4 4 0 0 1-8 0L7 4Z" fill="white"/><path d="M6 20h12M9 14l-2 6M15 14l2 6" stroke="white" stroke-width="2" stroke-linecap="round"/></svg></div>
