          <div class="footer-contact">
            <a href="tel:2405550162"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg><span>(240) 555-0162</span></a>
            <div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg><span>152 Gibbs St, Rockville, MD 20850</span></div>
          </div>
        </div>
        <div class="footer-column">
          <h3>Services</h3>
          <ul>
            <li><a href="/services/">Recurring Cleaning</a></li>
            <li><a href="/services/">Deep Cleaning</a></li>
            <li><a href="/services/">Move-In Cleaning</a></li>
            <li><a href="/services/">Move-Out Cleaning</a></li>
