---
const { title = 'House Cleaning Rockville', description = 'Rockville house cleaning for recurring maid service, deep cleaning, move-in and move-out cleaning, kitchen cleaning, bathroom cleaning, and apartment cleaning.', image = '/images/hero-home.png' } = Astro.props;
const siteUrl = 'https://housecleaningrockville.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const imageUrl = new URL(image, siteUrl);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'House Cleaning Rockville',
  url: siteUrl,
  image: imageUrl.href,
  description,
  telephone: '(240) 555-0162',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '152 Gibbs St',
    addressLocality: 'Rockville',
    addressRegion: 'MD',
    postalCode: '20850',
    addressCountry: 'US'
  },
  areaServed: 'Rockville, Maryland',
  priceRange: '$$'
};
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl.href} />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl.href} />
<meta property="og:url" content={canonicalUrl.href} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl.href} />
<link rel="sitemap" type="application/xml" href="/sitemap.xml" />
<link rel="icon" href="/favicon.svg" />
<script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
